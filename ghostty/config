# Ghostty config — docs: https://ghostty.org/docs/config

font-family = JetBrainsMono Nerd Font
font-size = 13

theme = catppuccin-mocha

# macOS option key as alt (needed for some tmux/vim bindings)
macos-option-as-alt = true

# Larger scrollback (tmux handles most of it, but useful outside tmux)
scrollback-limit = 100000

window-padding-x = 4
window-padding-y = 2

# Don't confirm when closing a window with a running process (tmux survives via server)
confirm-close-surface = false
